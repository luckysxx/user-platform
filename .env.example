# App
APP_ENV=development
SERVER_PORT=8081
GRPC_SERVER_PORT=9091
JWT_SECRET=replace_with_a_secure_secret

# Database
DATABASE_DRIVER=postgres
DATABASE_SOURCE=postgres://<db_user>:<db_password>@localhost:5432/user_platform?sslmode=disable
DATABASE_AUTO_MIGRATE_HTTP=true
DATABASE_AUTO_MIGRATE_GRPC=false

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=<redis_password>
REDIS_DB=0

# Infra
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_USER_REGISTERED=user.registered
ID_GENERATOR_ADDR=localhost:50059
OTEL_JAEGER_ENDPOINT=localhost:4318
OTEL_SERVICE_NAME_HTTP=user-platform-http
OTEL_SERVICE_NAME_GRPC=user-platform-grpc
METRICS_PORT=9092

# SMS Auth (Aliyun)
SMS_AUTH_ENABLED=false
SMS_AUTH_ACCESS_KEY_ID=
SMS_AUTH_ACCESS_KEY_SECRET=
SMS_AUTH_REGION=cn-hangzhou
SMS_AUTH_DEBUG_MODE=true
SMS_AUTH_SIGN_NAME=
SMS_AUTH_TEMPLATE_CODE=
SMS_AUTH_SCHEME_NAME=phoneLogin
SMS_AUTH_COUNTRY_CODE=86
SMS_AUTH_TEMPLATE_PARAM_JSON={"code":"##code##","min":"5"}
SMS_AUTH_CODE_LENGTH=6
SMS_AUTH_INTERVAL_SECONDS=60
SMS_AUTH_VALID_TIME_SECONDS=300
SMS_AUTH_CODE_TYPE=1
SMS_AUTH_DUPLICATE_POLICY=1
SMS_AUTH_AUTO_RETRY=1
